
# Optional desktop control API for phone -> computer control
DESKTOP_REMOTE_API_HOST=0.0.0.0
DESKTOP_REMOTE_API_PORT=3210
# Leave empty to disable auth in local development. Set a strong token for LAN use.
DESKTOP_REMOTE_API_TOKEN=
DESKTOP_REMOTE_PAIR_PASSWORD=
DESKTOP_REMOTE_AUTO_APPROVE=false
# Control-session heartbeat timeout in milliseconds.
DESKTOP_REMOTE_SESSION_TIMEOUT_MS=120000
